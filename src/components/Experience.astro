---

<section id="experience" class="py-24 px-6">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-2xl font-bold text-[var(--color-primary)] mb-12">Professional Experience</h2>
    <div class="space-y-12">
      {experiences.map((exp) => (
        <article class="relative pl-8 border-l-2 border-[var(--color-border)] hover:border-accent transition-colors">
          <div class="absolute -left-[7px] top-0 w-3 h-3 rounded-full bg-accent" />
          <div class="flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-4 mb-3">
            <h3 class="text-lg font-bold text-[var(--color-primary)]">
              <a href={exp.companyUrl} target="_blank" class="hover:text-accent transition-colors">
                {exp.company}
              </a>
              <span class="text-[var(--color-text-light)] font-normal text-sm ml-2">| {exp.tech}</span>
            </h3>
            <span class="text-sm text-[var(--color-text-light)]">{exp.period}</span>
          </div>
          <p class="text-accent font-medium text-sm mb-4">{exp.role}</p>
          <ul class="space-y-2">
            {exp.items.map((item) => (
              <li class="text-[var(--color-text-light)] text-sm leading-relaxed pl-4 relative before:content-[''] before:absolute before:left-0 before:top-2 before:w-1.5 before:h-1.5 before:rounded-full before:bg-[var(--color-card-border)]">
                {item}
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>
