---

<section id="education" class="py-24 px-6">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-2xl font-bold text-[var(--color-primary)] mb-12">Education & Achievements</h2>
    <div class="grid md:grid-cols-2 gap-8">
      <div class="bg-[var(--color-bg)] rounded-xl p-6 border border-[var(--color-card-border)]">
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 bg-accent/10 rounded-lg flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" />
            </svg>
          </div>
          <div>
            <h3 class="text-lg font-bold text-[var(--color-primary)]">Chittagong University of Engineering & Technology</h3>
            <p class="text-accent text-sm font-medium mt-1">B.Sc. in Computer Science & Engineering</p>
            <p class="text-[var(--color-text-light)] text-sm mt-1">2018 - 2023</p>
            <p class="text-[var(--color-text-light)] text-sm">Grade: 3.05 / 4.00</p>
          </div>
        </div>
      </div>
      <div class="bg-[var(--color-bg)] rounded-xl p-6 border border-[var(--color-card-border)]">
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 bg-accent/10 rounded-lg flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <div>
            <h3 class="text-lg font-bold text-[var(--color-primary)]">Competitive Programming</h3>
            <p class="text-[var(--color-text-light)] text-sm mt-2 leading-relaxed">
              Solved <span class="text-accent font-semibold">600+</span> problems across online judges
            </p>
            <div class="flex gap-4 mt-3">
              <a href="https://www.stopstalk.com/user/profile/invisibleguest" target="_blank" class="text-sm text-accent hover:underline">StopStalk</a>
              <a href="https://leetcode.com/u/user7083T/" target="_blank" class="text-sm text-accent hover:underline">LeetCode</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
